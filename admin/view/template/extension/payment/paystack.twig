<div class="container-fluid">
  <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-paystack" class="form-horizontal">
    <div class="card">
      <div class="card-header">
        <h3>{{ heading_title }}</h3>
      </div>
      <div class="card-body">
        <div class="form-group row">
          <label class="col-sm-2 col-form-label" for="input-public-key">{{ entry_public_key }}</label>
          <div class="col-sm-10">
            <input type="text" name="payment_paystack_public_key" value="{{ payment_paystack_public_key }}" placeholder="{{ entry_public_key }}" id="input-public-key" class="form-control" />
          </div>
        </div>

        <div class="form-group row">
          <label class="col-sm-2 col-form-label" for="input-secret-key">{{ entry_secret_key }}</label>
          <div class="col-sm-10">
            <input type="text" name="payment_paystack_secret_key" value="{{ payment_paystack_secret_key }}" placeholder="{{ entry_secret_key }}" id="input-secret-key" class="form-control" />
          </div>
        </div>

        <div class="form-group row">
          <label class="col-sm-2 col-form-label" for="input-order-status">{{ entry_order_status }}</label>
          <div class="col-sm-10">
            <select name="payment_paystack_order_status_id" id="input-order-status" class="form-control">
              {% for order_status in order_statuses %}
                <option value="{{ order_status.order_status_id }}" {% if order_status.order_status_id == payment_paystack_order_status_id %}selected{% endif %}>{{ order_status.name }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        <div class="form-group row">
          <label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
          <div class="col-sm-10">
            <select name="payment_paystack_status" id="input-status" class="form-control">
              <option value="1" {% if payment_paystack_status %}selected{% endif %}>Enabled</option>
              <option value="0" {% if not payment_paystack_status %}selected{% endif %}>Disabled</option>
            </select>
          </div>
        </div>

        <div class="form-group row">
          <label class="col-sm-2 col-form-label" for="input-sort-order">{{ entry_sort_order }}</label>
          <div class="col-sm-10">
            <input type="text" name="payment_paystack_sort_order" value="{{ payment_paystack_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
          </div>
        </div>
      </div>
      <div class="card-footer">
        <button type="submit" class="btn btn-primary">{{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-secondary">{{ button_cancel }}</a>
      </div>
    </div>
  </form>
</div>