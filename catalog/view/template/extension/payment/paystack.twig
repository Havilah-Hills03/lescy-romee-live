<button id="paystack-btn">Pay with Paystack</button>

<script src="https://js.paystack.co/v1/inline.js"></script>
<script>
document.getElementById('paystack-btn').addEventListener('click', function(){
    var handler = PaystackPop.setup({
        key: '{{ public_key }}',
        email: '{{ customer.email }}',
        amount: {{ total }},
        currency: 'NGN',
        callback: function(response){
            window.location.href = 'index.php?route=extension/payment/paystack/callback&reference=' + response.reference;
        },
        onClose: function(){
            alert('Payment cancelled.');
        }
    });
    handler.openIframe();
});
</script>